.PHONY: dev build start test lint clean docker-up docker-down db-migrate db-seed db-studio

# ─── Development ────────────────────────────────────────────
dev:
	npm run dev

build:
	npm run build

start:
	npm run start

# ─── Testing ────────────────────────────────────────────────
test:
	npm run test

test-watch:
	npm run test:watch

test-coverage:
	npm run test:coverage

# ─── Linting ────────────────────────────────────────────────
lint:
	npm run lint

# ─── Database ───────────────────────────────────────────────
db-migrate:
	npx prisma migrate dev

db-migrate-prod:
	npx prisma migrate deploy

db-seed:
	npm run db:seed

db-studio:
	npx prisma studio

db-generate:
	npx prisma generate

# ─── Docker ─────────────────────────────────────────────────
docker-up:
	docker compose up -d

docker-down:
	docker compose down

docker-logs:
	docker compose logs -f

# ─── Setup ──────────────────────────────────────────────────
setup: docker-up
	npm install
	cp -n .env.example .env || true
	npx prisma generate
	npx prisma migrate dev
	@echo "✅ Setup complete. Run 'make dev' to start."

# ─── Clean ──────────────────────────────────────────────────
clean:
	rm -rf .next node_modules coverage
